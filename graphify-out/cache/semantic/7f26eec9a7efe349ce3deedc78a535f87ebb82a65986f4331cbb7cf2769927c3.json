{"nodes": [{"id": "design_corespace_system", "label": "Corespace Design System (DESIGN.md)", "file_type": "document", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_marked_up_study_desk", "label": "Creative North Star: The Marked-Up Study Desk", "file_type": "rationale", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Interface should feel like a focused study desk with useful annotations in the margins. Direct, tactile, and a little handmade but serious enough for real IB work. Supports the student trying to make progress now, not perform productivity."}, {"id": "design_highlighter_rule", "label": "The Highlighter Rule", "file_type": "rationale", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Pastels should mark categories, availability, and key student actions. Do not wash whole screens in pastel."}, {"id": "design_ink_rule", "label": "The Ink Rule", "file_type": "rationale", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Borders are part of the identity. Use the same ink color and 2px stroke consistently rather than mixing gray outlines."}, {"id": "design_flat_until_action", "label": "The Flat-Until-Action Rule", "file_type": "rationale", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Surfaces stay flat until interaction. Card bump shadow (8px 8px 0 0) only on hover for clickable cards. Do not add ambient dashboard shadows or floating glass panels."}, {"id": "design_no_display_ui_rule", "label": "The No-Display-UI Rule", "file_type": "rationale", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Product controls, labels, and data should use the system sans. Save hero-scale type for true page heroes."}, {"id": "design_tok_prompt_cards", "label": "TOK Prompt Cards Component", "file_type": "document", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_anti_patterns", "label": "Design Anti-patterns (glassmorphism, gradient text, ambient shadow)", "file_type": "rationale", "source_file": "DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Explicitly forbidden: glassmorphism, gradient text, decorative blur, ambient shadow systems, em dashes or double hyphens in copy, side-stripe border accents, color-only state encoding for TOK categories."}], "edges": [{"source": "design_marked_up_study_desk", "target": "design_corespace_system", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "design_highlighter_rule", "target": "design_corespace_system", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "design_ink_rule", "target": "design_corespace_system", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "design_flat_until_action", "target": "design_corespace_system", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md", "source_location": null, "weight": 1.0}, {"source": "design_no_display_ui_rule", "target": "design_corespace_system", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1